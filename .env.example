# MongoDB Connection String
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority"

# Google Service Account JSON for Google Drive API
# Pastikan bentuknya berupa string JSON yang valid (dalam satu baris panjang atau string literal).
GOOGLE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "...", ...}'

# Admin Authentication
ADMIN_PASSWORD="password_anda_di_sini"

# Gemini API Key untuk OCR
GEMINI_API_KEY="AIzaSy..."
